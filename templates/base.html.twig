<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport"
          content="width=device-width, user-scalable=yes, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>{% block title %}Création d'annonce du match du weekend - {% endblock %}</title>
    <link rel="icon" href="{{ asset('images/logo_llh.png') }}">

    {% block stylesheets %}
    {% endblock %}

    {% block javascripts %}
        {% block importmap %}
            {{ importmap('app') }}
        {% endblock %}
    {% endblock %}
</head>
<body>
<main>
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}
    {% block body %}
    <h1>Création des annonces du weekend</h1>
    <section class="container">
        {% block section %}
            {# Emplacement du corps de la vue #}
        {% endblock %}
    </section>
    {% endblock %}
</main>
<footer>
    &copy; Le Landreau Handball {{ "now"|date("Y") }}
</footer>
</body>
</html>
